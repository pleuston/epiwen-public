<!-- OBJECT file — the inscribed boulder near 光化寺 Guanghua Monastery (E25 feature), bearing
     FOUR texts on at least TWO faces: CLS_5/6/7 on the SW face (azimuth 216°) and CLS_8 on an
     ESE face (azimuth 107°). Like 映佛巖, anchor-less: faces are distinguished per text by the
     orientation notes in the inscription files, not by nested face anchors (README discusses
     when to prefer which idiom). The single-boulder identity of CLS_5–8 is the project's
     determination (see sourceDesc). Object-level listWit: the ensemble rubbings that cover
     several of the texts on one sheet. -->
<TEI xmlns="http://www.tei-c.org/ns/1.0" xml:id="CLS_Guanghuasi_stone">
  <teiHeader>
    <fileDesc>
      <titleStmt>
        <title xml:lang="zh">光化寺刻石</title>
        <title xml:lang="en">Inscribed boulder near Guanghua Monastery</title>
      </titleStmt>
      <publicationStmt>
        <authority>Epiwen / EpiDoc-CN profile — sample</authority>
        <idno type="object">CLS_Guanghuasi</idno>
        <availability status="restricted"><p>Demonstration set, published in the Epiwen public corpus; rights remain with the source providers.</p></availability>
      </publicationStmt>
      <sourceDesc>
        <bibl>assembled from <ptr target="sutras:catalog/CLS_5.xml"/>–<ptr target="sutras:catalog/CLS_8.xml"/>
          (titles: 光化寺刻石／"on the Boulder near Guanghua Monastery"). The single-boulder
          identity of CLS_5–8 is the project editor's determination from the shared bearer naming,
          the joint ensemble rubbings, and the adjacent GPS points; CLS_8's azimuth (107° vs 216°)
          places it on a different face of the same boulder. {verify against the site publication}</bibl>
      </sourceDesc>
    </fileDesc>
    <encodingDesc>
      <listPrefixDef>
        <prefixDef ident="crm" matchPattern="(.+)" replacementPattern="http://www.cidoc-crm.org/cidoc-crm/$1"/>
        <prefixDef ident="crmtex" matchPattern="(.+)" replacementPattern="http://www.cidoc-crm.org/extensions/crmtex/$1"/>
